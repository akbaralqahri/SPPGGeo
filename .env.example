# Public Supabase project values. The anon/publishable key is safe in browser
# code only when Row Level Security from supabase/schema.sql is enabled.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# auto: prefer database when configured, fall back to bundled snapshot
# snapshot: always use the bundled snapshot on the public dashboard
SPPG_DATA_MODE=auto

# Provenance shown in the public dashboard
DATASET_AS_OF=
DATA_SOURCE_NAME=Tabel SPPG yang diberikan (315 baris)
DATA_SOURCE_URL=
SITE_URL=
